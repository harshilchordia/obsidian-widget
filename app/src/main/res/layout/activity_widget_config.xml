<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/obsidian_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️ Configure Widget"
            android:textColor="@color/obsidian_text"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Vault Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vault Folder"
            android:textColor="@color/obsidian_accent"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/config_vault_path"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="No vault selected"
                android:textColor="@color/obsidian_text_secondary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/config_select_vault"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/button_background"
                android:text="Select"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />
        </LinearLayout>

        <!-- Note Mode Toggle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/note_mode_label"
            android:textColor="@color/obsidian_accent"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/config_note_mode_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="horizontal"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/config_radio_daily"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/mode_daily_note"
                android:textColor="@color/obsidian_text"
                android:buttonTint="@color/obsidian_accent" />

            <RadioButton
                android:id="@+id/config_radio_pinned"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/mode_specific_note"
                android:textColor="@color/obsidian_text"
                android:buttonTint="@color/obsidian_accent" />
        </RadioGroup>

        <!-- Pinned Note Selection -->
        <LinearLayout
            android:id="@+id/config_pinned_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pinned_note_label"
                android:textColor="@color/obsidian_accent"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/config_pinned_note_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/no_note_selected"
                    android:textColor="@color/obsidian_text_secondary"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/config_select_note"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/button_background"
                    android:text="@string/select_note"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Daily Notes Folder (shown when Daily Note selected) -->
        <LinearLayout
            android:id="@+id/config_daily_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily Notes Subfolder"
                android:textColor="@color/obsidian_accent"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/config_daily_folder"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/card_background"
                android:hint="@string/daily_notes_hint"
                android:textColor="@color/obsidian_text"
                android:textColorHint="@color/obsidian_text_secondary"
                android:textSize="14sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text" />
        </LinearLayout>

        <!-- Save Button -->
        <Button
            android:id="@+id/config_save"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/button_background"
            android:text="@string/save_widget"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textAllCaps="false" />

    </LinearLayout>
</ScrollView>
