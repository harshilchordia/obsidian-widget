<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header: Title + Refresh -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📝"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="5"
            android:text="Daily Note"
            android:textColor="@color/obsidian_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/widget_refresh"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Refresh"
            android:src="@android:drawable/stat_notify_sync"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- Note Preview (shown when no checklist items) -->
    <TextView
        android:id="@+id/widget_note_preview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:background="@drawable/card_background"
        android:padding="10dp"
        android:text="@string/no_vault_selected"
        android:textColor="@color/obsidian_text_secondary"
        android:textSize="13sp"
        android:maxLines="8"
        android:ellipsize="end"
        android:visibility="gone" />

    <!-- Interactive Checklist (shown when note has checklist items) -->
    <ListView
        android:id="@+id/widget_checklist"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:background="@drawable/card_background"
        android:divider="@android:color/transparent"
        android:dividerHeight="0dp"
        android:scrollbars="vertical"
        android:fadingEdge="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:clipToPadding="false" />

    <!-- Bottom Buttons: always visible -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/widget_btn_capture"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="2dp"
            android:background="@drawable/button_background"
            android:text="✏️ Capture"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/widget_btn_open"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:background="@drawable/card_background"
            android:text="📂 Open Note"
            android:textColor="@color/obsidian_accent"
            android:textSize="11sp"
            android:textAllCaps="false" />
    </LinearLayout>

</LinearLayout>
